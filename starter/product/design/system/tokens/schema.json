{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-framework.dev/schemas/design-tokens-v1.json",
  "type": "object",
  "required": ["schemaVersion", "system", "version", "tokens"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "system": { "pattern": "^DSYS-[0-9]{3,}$" },
    "version": { "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
    "tokens": { "type": "object" }
  }
}
