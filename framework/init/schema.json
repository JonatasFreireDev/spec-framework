{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-framework.dev/schemas/init-contract-v1.json",
  "title": "Spec Framework initialization contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "asset_sets",
    "directories",
    "files",
    "patches",
    "registry",
    "bootstrap_profile",
    "actions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "asset_sets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "directories": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file" }
    },
    "patches": {
      "type": "array",
      "items": { "$ref": "#/$defs/patch" }
    },
    "registry": { "$ref": "#/$defs/registry" },
    "bootstrap_profile": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["create-import-run"] }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "replacements"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "replacements": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "find", "replace"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "find": { "type": "string", "minLength": 1 },
        "replace": { "type": "string" }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exclude_types": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "prepend_artifacts": {
          "type": "array",
          "items": { "type": "object" }
        },
        "append_parents_by_type": { "$ref": "#/$defs/parentsByType" },
        "replace_parents_by_type": { "$ref": "#/$defs/parentsByType" }
      }
    },
    "parentsByType": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1 }
      }
    }
  }
}
